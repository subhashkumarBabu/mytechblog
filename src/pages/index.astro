---
import AirLayout from "../layouts/AirLayout.astro";
import { RANDOM_SQL } from "./api/landing";

export const prerender = false;

type Link = {
  id: string; type: string; title: string | null;
  url: string | null; tags: string; created_at: string;
};

const env = Astro.locals.runtime?.env;
let cards: Link[] = [];
let total = 0;

if (env?.DB) {
  const [randomRes, countRes] = await Promise.all([
    env.DB.prepare(RANDOM_SQL).all(),
    env.DB.prepare("SELECT COUNT(*) AS n FROM links").first<{ n: number }>(),
  ]);
  cards = randomRes.results as Link[];
  total = countRes?.n ?? 0;
}

const totalFmt = total.toLocaleString("en-US");
const TOPICS = ["ai-agents", "llms", "rag", "azure", "kubernetes", "devops"];
---

<AirLayout
  title={`devopsmantra — ${totalFmt} links, curated over 14 years`}
  description={`A living knowledge base: ${totalFmt} hand-picked links on DevOps, Azure, Kubernetes and AI, organized into topic pages by an AI librarian.`}
  active="home"
>
  <header class="hero">
    <h1 class="display"><em>{totalFmt}</em> links,<br />curated over 14 years.</h1>
    <p class="annot">organized by an AI librarian ↓</p>
  </header>

  <input class="input search" id="q" type="search" placeholder="Search the whole collection…" autocomplete="off" />
  <div class="rail" id="rail">
    <button class="chip on" data-topic="">All</button>
    {TOPICS.map((t) => <button class="chip" data-topic={t}>{t}</button>)}
  </div>

  <div class="headrow">
    <h2 id="head">Five from the vault</h2>
    <button class="btn" id="shuffle">Shuffle</button>
  </div>

  <div class="grid" id="grid" data-initial={JSON.stringify(cards)}></div>
  <button class="btn more" id="more" hidden>Show 10 more</button>

  <style>
    .hero { margin-bottom: var(--gap-section); }
    .hero h1 { font-size: clamp(40px, 7.5vw, 84px); }
    .hero .annot { margin-top: 14px; }

    .search { margin-bottom: 14px; }
    .headrow {
      display: flex; justify-content: space-between; align-items: center;
      margin: 34px 0 18px;
    }
    .headrow h2 { font-family: var(--display); font-weight: 400; font-size: 20px;
      letter-spacing: .5px; text-transform: uppercase; color: var(--whiteout); }

    .grid {
      display: grid; gap: 14px;
      grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
    }
    .more { width: 100%; margin-top: 16px; }
  </style>

  <style is:global>
    .lk {
      display: flex; flex-direction: column; gap: 10px; min-height: 168px;
      background: var(--stock, var(--haze)); color: var(--ink);
      border-radius: var(--r-card); padding: var(--pad-card);
      text-decoration: none;
      animation: deal .34s cubic-bezier(.2, .8, .3, 1) both;
      animation-delay: var(--d, 0ms);
      transition: transform .15s;
    }
    @keyframes deal { from { opacity: 0; transform: translateY(14px); } }
    .lk:hover { transform: translateY(-2px); }
    .lk:hover .t { text-decoration: underline; text-decoration-color: var(--signal); text-underline-offset: 3px; }
    .lk .kick {
      display: flex; justify-content: space-between; gap: 8px;
      font-size: 11.5px; font-weight: 600; letter-spacing: .8px; text-transform: uppercase;
      color: var(--ink-2);
    }
    .lk .kick span:first-child { color: var(--stock-ink, var(--ink-2)); }
    .lk .t { font-size: 16px; font-weight: 600; line-height: 1.35; color: var(--ink);
      display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden; }
    .lk .meta { margin-top: auto; display: flex; justify-content: space-between; align-items: baseline; gap: 8px;
      font-size: 12.5px; color: var(--ink-2); }
    .lk .meta .dom { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .lk .tag { flex: none; color: var(--stock-ink, var(--signal)); font-weight: 600; }
    .grid .lk:first-child { grid-column: span 2; }
    .grid .lk:first-child .t { font-size: 22px; }
    @media (max-width: 540px) { .grid .lk:first-child { grid-column: span 1; } }
  </style>

  <script>
    const grid = document.getElementById("grid")!;
    const head = document.getElementById("head")!;
    const more = document.getElementById("more") as HTMLButtonElement;
    const shuffle = document.getElementById("shuffle") as HTMLButtonElement;
    const input = document.getElementById("q") as HTMLInputElement;

    type Row = { id: string; type: string; title: string; url: string; tags: string; created_at: string };

    const TYPE_LABEL: Record<string, string> = {
      YouTubeVideo: "Video", Repository: "Repo", Article: "Article",
      Document: "Doc", WebPage: "Web", Note: "Note",
    };

    const esc = (s: string) => s.replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" })[c]!);

    function tile(l: Row, i: number): string {
      let tags: string[] = [];
      try { tags = JSON.parse(l.tags || "[]"); } catch {}
      const topic = tags[0] ?? "";
      const domain = (() => { try { return new URL(l.url).hostname.replace(/^www\./, ""); } catch { return ""; } })();
      const year = (l.created_at || "").slice(0, 4);
      return `<a class="lk t-${esc(l.type)}" style="--d:${Math.min(i, 10) * 45}ms" href="${esc(l.url)}" target="_blank" rel="noopener">
        <div class="kick"><span>${TYPE_LABEL[l.type] ?? "Web"}</span><span>${year}</span></div>
        <h3 class="t">${esc(l.title ?? domain)}</h3>
        <div class="meta"><span class="dom">${esc(domain)}</span>${topic ? `<span class="tag">${esc(topic)}</span>` : ""}</div>
      </a>`;
    }

    function render(rows: Row[]) {
      grid.innerHTML = rows.map(tile).join("");
    }

    let topic = "", offset = 0, rows: Row[] = [];

    async function load(append = false) {
      const q = input.value.trim();
      const searching = q.length > 0;
      shuffle.hidden = searching;
      if (!append) offset = 0;
      const p = new URLSearchParams({ q, offset: String(offset) });
      if (topic) p.set("tag", topic);
      const res = await fetch(`/api/landing/?${p}`);
      const data = await res.json();
      rows = append ? rows.concat(data.links) : data.links;
      render(rows);
      if (searching) {
        head.textContent = `${data.total.toLocaleString()} result${data.total === 1 ? "" : "s"}`;
        more.hidden = rows.length >= data.total;
      } else {
        head.textContent = topic ? `Five from ${topic}` : "Five from the vault";
        more.hidden = true;
      }
    }

    render(JSON.parse(grid.dataset.initial || "[]"));
    grid.removeAttribute("data-initial");

    let t: ReturnType<typeof setTimeout>;
    input.addEventListener("input", () => { clearTimeout(t); t = setTimeout(() => load(), 250); });
    shuffle.addEventListener("click", () => load());
    more.addEventListener("click", () => { offset += 10; load(true); });
    document.querySelectorAll<HTMLButtonElement>(".chip").forEach((c) =>
      c.addEventListener("click", () => {
        topic = c.dataset.topic ?? "";
        document.querySelectorAll(".chip").forEach((x) => x.classList.toggle("on", x === c));
        load();
      }),
    );
  </script>
</AirLayout>

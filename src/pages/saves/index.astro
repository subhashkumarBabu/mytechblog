---
import MainGridLayout from "@layouts/MainGridLayout.astro";

const env = Astro.locals.runtime?.env;

type Link = {
  id: string; type: string; title: string | null; url: string | null;
  summary: string | null; tags: string; created_at: string; is_read: number;
};

let initialLinks: Link[] = [];
let total = 0;

if (env?.DB) {
  const [res, countRes] = await Promise.all([
    env.DB.prepare("SELECT id, type, title, url, summary, tags, created_at, is_read FROM links ORDER BY created_at DESC LIMIT 50").all(),
    env.DB.prepare("SELECT COUNT(*) as n FROM links").first<{n:number}>(),
  ]);
  initialLinks = res.results as Link[];
  total = countRes?.n ?? 0;
}

const TYPE_HUE: Record<string, string> = {
  Article: "240", Repository: "150", WebPage: "300",
  Document: "60", Note: "350", YouTubeVideo: "10",
};

const TYPES = ["All", "Article", "Repository", "YouTubeVideo", "WebPage", "Document", "Note"];
---

<MainGridLayout title="Saves — DevOps Mantra" description="My saved links and resources">

  <!-- Header + filters -->
  <div class="card-base p-5 mb-5 onload-animation">
    <input
      id="search-input"
      type="search"
      placeholder="Search titles, tags, summaries…"
      class="w-full rounded-lg px-3 py-2 text-sm bg-[var(--btn-regular-bg)] border border-[var(--line-color)] focus:outline-none focus:border-[var(--primary)] transition text-[var(--deep-text)] mb-3"
    />

    <!-- Type filters -->
    <div class="flex flex-wrap gap-2">
      {TYPES.map((t) => (
        <button
          class="type-filter text-xs px-3 py-1 rounded-full transition font-medium"
          data-type={t.toLowerCase()}
          style={t === "All" ? "background:var(--primary);color:white" : "background:var(--btn-regular-bg);color:var(--btn-content)"}
        >
          {t}
        </button>
      ))}
    </div>
  </div>

  <!-- Stats -->
  <p id="count-label" class="text-sm text-75 mb-3 onload-animation" style="animation-delay:50ms">
    Showing <strong id="shown-count">{initialLinks.length}</strong> of <strong id="total-count">{total}</strong> saves
  </p>

  <!-- Grid -->
  <div id="saves-grid" class="flex flex-col gap-3 onload-animation" style="animation-delay:100ms">
    {initialLinks.map((link) => {
      const hue = TYPE_HUE[link.type] ?? "250";
      const tags = (() => { try { return JSON.parse(link.tags) ?? []; } catch { return []; } })();
      const domain = link.url ? (() => { try { return new URL(link.url).hostname.replace("www.", ""); } catch { return ""; } })() : "";
      return (
        <div
          class="save-card card-base p-4 transition"
          data-type={link.type.toLowerCase()}
          data-title={(link.title ?? "").toLowerCase()}
          data-tags={link.tags.toLowerCase()}
          data-summary={(link.summary ?? "").toLowerCase()}
        >
          <div class="flex items-start gap-3">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 flex-wrap mb-1">
                <span class="text-[10px] px-2 py-0.5 rounded-full font-medium shrink-0"
                  style={`background:oklch(0.92 0.05 ${hue});color:oklch(0.45 0.12 ${hue})`}>
                  {link.type}
                </span>
                {link.is_read === 1 && <span class="text-[10px] text-75">✓ read</span>}
              </div>
              <a
                href={link.url ?? "#"}
                target={link.url ? "_blank" : undefined}
                rel="noopener noreferrer"
                class="font-medium text-sm text-[var(--deep-text)] hover:text-[var(--primary)] transition line-clamp-2 block mb-1"
              >
                {link.title ?? link.url ?? "Untitled"}
              </a>
              {link.summary && <p class="text-xs text-75 line-clamp-2 mb-2">{link.summary}</p>}
              <div class="flex items-center gap-3 flex-wrap">
                {tags.slice(0, 5).map((t: string) => (
                  <span class="tag-pill text-[10px] px-1.5 py-0.5 rounded bg-[var(--btn-regular-bg)] text-[var(--btn-content)] cursor-pointer hover:bg-[var(--btn-regular-bg-hover)] transition" data-tag={t}>{t}</span>
                ))}
                {domain && <span class="text-[10px] text-75 ml-auto">{domain}</span>}
              </div>
            </div>
          </div>
        </div>
      );
    })}
  </div>

  <!-- Load more -->
  <div class="text-center mt-6">
    <button
      id="load-more-btn"
      class="btn-regular rounded-lg px-6 py-2 text-sm font-medium text-[var(--btn-content)] hover:bg-[var(--btn-regular-bg-hover)] transition"
      data-offset={initialLinks.length}
      data-total={total}
      style={total <= initialLinks.length ? "display:none" : ""}
    >
      Load more
    </button>
  </div>

</MainGridLayout>

<script>
  const TYPE_HUE: Record<string, string> = {
    Article: '240', Repository: '150', WebPage: '300',
    Document: '60', Note: '350', YouTubeVideo: '10',
  };

  function renderCard(link: any): HTMLElement {
    const hue = TYPE_HUE[link.type as string] ?? '250';
    const tags: string[] = (() => { try { return JSON.parse(link.tags) ?? []; } catch { return []; } })();
    const domain = link.url ? (() => { try { return new URL(link.url).hostname.replace('www.', ''); } catch { return ''; } })() : '';
    const card = document.createElement('div');
    card.className = 'save-card card-base p-4 transition';
    const esc = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    const safeTitle = esc(link.title ?? link.url ?? 'Untitled');
    const safeSummary = esc(link.summary ?? '');
    const safeType = esc(link.type as string);
    const tagHtml = tags.slice(0, 5).map((t: string) => {
      const safe = esc(t);
      return `<span class="tag-pill text-[10px] px-1.5 py-0.5 rounded bg-[var(--btn-regular-bg)] text-[var(--btn-content)] cursor-pointer hover:bg-[var(--btn-regular-bg-hover)] transition" data-tag="${safe}">${safe}</span>`;
    }).join('');
    const safeUrl = link.url ? encodeURI(link.url) : '#';
    card.innerHTML = `
      <div class="flex items-start gap-3">
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 flex-wrap mb-1">
            <span class="text-[10px] px-2 py-0.5 rounded-full font-medium shrink-0" style="background:oklch(0.92 0.05 ${hue});color:oklch(0.45 0.12 ${hue})">${safeType}</span>
            ${link.is_read ? '<span class="text-[10px] text-75">read</span>' : ''}
          </div>
          <a href="${safeUrl}" ${link.url ? 'target="_blank" rel="noopener noreferrer"' : ''}
            class="font-medium text-sm text-[var(--deep-text)] hover:text-[var(--primary)] transition line-clamp-2 block mb-1">
            ${safeTitle}
          </a>
          ${safeSummary ? `<p class="text-xs text-75 line-clamp-2 mb-2">${safeSummary}</p>` : ''}
          <div class="flex items-center gap-3 flex-wrap">
            ${tagHtml}
            ${domain ? `<span class="text-[10px] text-75 ml-auto">${domain.replace(/</g, '&lt;')}</span>` : ''}
          </div>
        </div>
      </div>`;
    return card;
  }

  const initialized = new WeakSet<Element>();

  function initSavesPage() {
    const grid = document.getElementById('saves-grid');
    if (!grid) return;
    if (initialized.has(grid)) return;
    initialized.add(grid);

    const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
    const shownCount = document.getElementById('shown-count');
    const totalCount = document.getElementById('total-count');
    const loadMoreBtn = document.getElementById('load-more-btn') as HTMLButtonElement | null;

    let activeType = 'all';
    let searchQuery = '';
    let currentOffset = 50; // already have 50 from SSR
    let currentTotal = parseInt(loadMoreBtn?.dataset.total ?? '0');
    let debounceTimer: ReturnType<typeof setTimeout> | null = null;

    function setTypeButtons(type: string) {
      document.querySelectorAll<HTMLElement>('.type-filter').forEach(b => {
        const active = b.dataset.type === type;
        b.style.background = active ? 'var(--primary)' : 'var(--btn-regular-bg)';
        b.style.color = active ? 'white' : 'var(--btn-content)';
      });
    }

    async function fetchAndReplace() {
      grid.innerHTML = '<p class="text-sm text-75 text-center py-8">Loading…</p>';
      if (loadMoreBtn) loadMoreBtn.style.display = 'none';
      currentOffset = 0;

      const params = new URLSearchParams({ limit: '50', offset: '0' });
      if (activeType !== 'all') params.set('type', activeType);
      if (searchQuery) params.set('q', searchQuery);

      try {
        const res = await fetch(`/api/links?${params}`);
        const { links, total } = await res.json();
        currentTotal = total ?? 0;
        currentOffset = links?.length ?? 0;

        grid.innerHTML = '';
        if (!links?.length) {
          grid.innerHTML = '<p class="text-sm text-75 text-center py-8">No results found.</p>';
        } else {
          links.forEach((link: any) => grid.appendChild(renderCard(link)));
        }
        if (shownCount) shownCount.textContent = String(currentOffset);
        if (totalCount) totalCount.textContent = String(currentTotal);
        if (loadMoreBtn) {
          loadMoreBtn.style.display = currentOffset < currentTotal ? '' : 'none';
          loadMoreBtn.dataset.offset = String(currentOffset);
          loadMoreBtn.textContent = 'Load more';
          loadMoreBtn.disabled = false;
        }
      } catch {
        grid.innerHTML = '<p class="text-sm text-75 text-center py-8">Failed to load. Please refresh.</p>';
      }
    }

    // Type filter buttons
    document.querySelectorAll<HTMLElement>('.type-filter').forEach(btn => {
      btn.addEventListener('click', () => {
        activeType = btn.dataset.type ?? 'all';
        setTypeButtons(activeType);
        fetchAndReplace();
      });
    });

    // Tag pill clicks — delegate from grid
    grid.addEventListener('click', (e) => {
      const pill = (e.target as HTMLElement).closest<HTMLElement>('.tag-pill');
      if (!pill) return;
      const tag = pill.dataset.tag ?? '';
      if (searchInput) searchInput.value = tag;
      searchQuery = tag;
      fetchAndReplace();
    });

    // Search input — debounced
    searchInput?.addEventListener('input', () => {
      searchQuery = searchInput.value.trim();
      if (debounceTimer) clearTimeout(debounceTimer);
      debounceTimer = setTimeout(fetchAndReplace, 350);
    });

    // Load more — respects current filters
    loadMoreBtn?.addEventListener('click', async () => {
      const offset = parseInt(loadMoreBtn.dataset.offset ?? '50');
      loadMoreBtn.textContent = 'Loading…';
      loadMoreBtn.disabled = true;

      const params = new URLSearchParams({ limit: '50', offset: String(offset) });
      if (activeType !== 'all') params.set('type', activeType);
      if (searchQuery) params.set('q', searchQuery);

      try {
        const res = await fetch(`/api/links?${params}`);
        const { links } = await res.json();
        if (!links?.length) { loadMoreBtn.style.display = 'none'; return; }
        links.forEach((link: any) => grid.appendChild(renderCard(link)));
        const newOffset = offset + links.length;
        loadMoreBtn.dataset.offset = String(newOffset);
        if (shownCount) shownCount.textContent = String(newOffset);
        // total-count stays the same on load more — filtered total already set
        loadMoreBtn.textContent = 'Load more';
        loadMoreBtn.disabled = false;
        if (links.length < 50) loadMoreBtn.style.display = 'none';
      } catch {
        loadMoreBtn.textContent = 'Error — try again';
        loadMoreBtn.disabled = false;
      }
    });
  }

  initSavesPage();

  function setupSwup() {
    (window as any).swup.hooks.on('page:view', initSavesPage);
  }
  if ((window as any).swup) {
    setupSwup();
  } else {
    document.addEventListener('swup:enable', setupSwup);
  }
</script>

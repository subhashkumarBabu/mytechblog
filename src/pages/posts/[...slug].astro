---
export const prerender = true;
import AirLayout from "@layouts/AirLayout.astro";
import { getSortedPosts } from "@utils/content-utils";
import { getPostUrlBySlug } from "@utils/url-utils";
import { profileConfig, siteConfig } from "../../config";
import { formatDateToYYYYMMDD } from "../../utils/date-utils";

export async function getStaticPaths() {
	const blogEntries = await getSortedPosts();
	return blogEntries.map((entry) => ({
		params: { slug: entry.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { remarkPluginFrontmatter } = await entry.render();

const date = new Date(entry.data.published).toLocaleDateString("en-GB", {
	day: "numeric", month: "short", year: "numeric",
});

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	headline: entry.data.title,
	description: entry.data.description || entry.data.title,
	keywords: entry.data.tags,
	author: {
		"@type": "Person",
		name: profileConfig.name,
		url: Astro.site,
	},
	datePublished: formatDateToYYYYMMDD(entry.data.published),
	inLanguage: entry.data.lang
		? entry.data.lang.replace("_", "-")
		: siteConfig.lang.replace("_", "-"),
};
---

<AirLayout title={`${entry.data.title} — devopsmantra`} description={entry.data.description || entry.data.title} active="blog">
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>

  <header class="head">
    <a class="crumb" href="/archive/">← blog</a>
    <h1 class="title">{entry.data.title}</h1>
    <p class="annot">
      {date}
      {entry.data.category && <> · {entry.data.category}</>}
      · {remarkPluginFrontmatter.minutes} min read
    </p>
    {entry.data.tags?.length > 0 && (
      <p class="tags">{entry.data.tags.map((tag: string) => <span class="tag">{tag}</span>)}</p>
    )}
  </header>

  <article class="prose">
    <Content />
  </article>

  <nav class="pn">
    {entry.data.nextSlug && (
      <a class="pn-link prev" href={getPostUrlBySlug(entry.data.nextSlug)}>
        <span class="dir">← Previous</span>
        <span class="t">{entry.data.nextTitle}</span>
      </a>
    )}
    {entry.data.prevSlug && (
      <a class="pn-link next" href={getPostUrlBySlug(entry.data.prevSlug)}>
        <span class="dir">Next →</span>
        <span class="t">{entry.data.prevTitle}</span>
      </a>
    )}
  </nav>

  <style>
    .head { margin-bottom: var(--gap-section); max-width: 820px; }
    .crumb { color: var(--faint); font-size: 13px; display: inline-block; margin-bottom: 14px; }
    .title {
      color: var(--whiteout); font-size: clamp(26px, 4.5vw, 42px);
      font-weight: 700; line-height: 1.2; letter-spacing: -0.5px;
    }
    .head .annot { margin-top: 12px; }
    .tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; }
    .tag {
      font-size: 11.5px; font-weight: 600; letter-spacing: .4px;
      color: var(--faint); border: 1px solid var(--hairline);
      border-radius: 4px; padding: 2px 8px;
    }

    .pn {
      display: flex; flex-wrap: wrap; gap: 14px; justify-content: space-between;
      margin-top: var(--gap-section); max-width: 820px;
    }
    .pn-link {
      display: flex; flex-direction: column; gap: 4px; flex: 1 1 260px;
      background: var(--haze); color: var(--ink);
      border-radius: var(--r-card); padding: var(--pad-card);
      text-decoration: none;
    }
    .pn-link.next { text-align: right; }
    .pn-link .dir { color: var(--ink-2); font-size: 12px; letter-spacing: .5px; text-transform: uppercase; }
    .pn-link .t { font-size: 14.5px; font-weight: 600; line-height: 1.35; }
    .pn-link:hover .t { text-decoration: underline; text-decoration-color: var(--signal); text-underline-offset: 3px; }
  </style>

  <style is:global>
    .prose { max-width: 820px; color: var(--mist); font-size: 15.5px; line-height: 1.7; }
    .prose h2 {
      font-family: var(--display); font-weight: 400; font-size: 22px;
      letter-spacing: .5px; text-transform: uppercase; color: var(--twilight);
      margin: 44px 0 14px;
    }
    .prose h3 { color: var(--whiteout); font-size: 17px; margin: 28px 0 10px; }
    .prose h4 { color: var(--whiteout); font-size: 15.5px; margin: 22px 0 8px; }
    .prose p { margin: 0 0 15px; }
    .prose strong { color: var(--whiteout); }
    .prose a { color: var(--signal); }
    .prose a:hover { text-decoration: underline; text-underline-offset: 3px; }
    .prose ul, .prose ol { margin: 0 0 16px; padding-left: 22px; }
    .prose li { margin-bottom: 7px; }
    .prose blockquote {
      border-left: 2px solid var(--signal); margin: 0 0 16px; padding: 2px 0 2px 16px;
      color: var(--faint);
    }
    .prose hr { border: 0; border-top: 1px solid var(--hairline); margin: 30px 0; }
    .prose code {
      font-family: ui-monospace, Consolas, monospace; font-size: 13.5px;
      background: var(--haze); color: var(--ink); border-radius: 4px; padding: 1px 6px;
    }
    .prose .expressive-code { margin: 0 0 18px; }
    .prose .expressive-code code { background: none; color: inherit; padding: 0; }
    .prose img { max-width: 100%; border-radius: var(--r-card); margin: 0 0 16px; }
    .prose table { border-collapse: collapse; font-size: 14px; margin: 0 0 18px; display: block; overflow-x: auto; }
    .prose th, .prose td { border: 1px solid var(--hairline); padding: 6px 12px; text-align: left; }
    .prose th { color: var(--whiteout); }
  </style>
</AirLayout>

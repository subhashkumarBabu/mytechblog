---
import AirLayout from "../layouts/AirLayout.astro";

export const prerender = false;

const ARC = [
  {
    when: "1995",
    what: "Programmer analyst. Built software for whoever walked in the door — printers, perfume makers, financial firms, coaching classes, car-rental agencies. Visual Basic, FoxPro, SQL, and a lot of listening.",
  },
  {
    when: "2007",
    what: "Enterprise consulting for European government and industry: document management, .NET, and a thirty-application portfolio that taught me estimation the hard way.",
  },
  {
    when: "2010",
    what: "Team-lead years: audit reporting systems and insurance platforms. Where I learned that trust in a system is built from its reports — and that reliability was a discipline before it had a name.",
  },
  {
    when: "2014",
    what: "Solutions architect for a very large UK retail estate. Architectural governance, migrations measured in millions, technology roadmaps that occasionally survived contact with reality — and a client hackathon won with an IoT build.",
  },
  {
    when: "2019",
    what: "DevOps architect for a national-scale estate. Pipelines in Azure DevOps, infrastructure written down in Terraform instead of clicked into existence, monitoring wired into ServiceNow — the plumbing autonomous operations would later stand on.",
  },
  {
    when: "2023",
    what: "The pivot. From keeping big systems boring — the highest compliment in SRE — to teaching them to fix themselves: LLMs and agentic AI, governed by policy, watched by telemetry.",
  },
  {
    when: "2026",
    what: "Built an adaptive learning engine in public: knowledge graphs, AI-graded recall, spaced repetition. Learning agentic engineering the way I'd architect it — systematically.",
  },
];

// tag = classifier name in D1; slug = wiki page; fb = fallback count if D1 unreachable
const INTERESTS = [
  { label: "LLMs", slug: "llms", tag: "llms", fb: 3267 },
  { label: "Azure", slug: "azure", tag: "azure", fb: 2437 },
  { label: "AI agents", slug: "ai-agents", tag: "ai-agents", fb: 1891 },
  { label: "Machine learning", slug: "machine-learning", tag: "machine-learning", fb: 1417 },
  { label: "DevOps", slug: "devops", tag: "devops", fb: 1195 },
  { label: "RAG", slug: "rag", tag: "rag", fb: 674 },
  { label: "Infrastructure as code", slug: "infrastructure-as-code", tag: "iac", fb: 626 },
  { label: "Prompt engineering", slug: "prompt-engineering", tag: "prompt-engineering", fb: 499 },
  { label: "SRE & observability", slug: "sre-and-observability", tag: "sre-observability", fb: 378 },
  { label: "Platform engineering", slug: "platform-engineering", tag: "platform-engineering", fb: 207 },
];

const env = Astro.locals.runtime?.env;
const counts: Record<string, number> = {};
let total = 19754;
let recent: { title: string; url: string; created_at: string }[] = [];

if (env?.DB) {
  try {
    const stmts = INTERESTS.map((t) =>
      env.DB.prepare("SELECT COUNT(*) AS n FROM links WHERE tags LIKE ?").bind(`%"${t.tag}"%`)
    );
    stmts.push(env.DB.prepare("SELECT COUNT(*) AS n FROM links"));
    stmts.push(env.DB.prepare("SELECT title, url, created_at FROM links ORDER BY created_at DESC LIMIT 3"));
    const res = await env.DB.batch(stmts);
    const dbTotal = (res[INTERESTS.length].results[0] as { n: number }).n;
    // a near-empty DB is local dev, not the vault — keep the baked-in numbers
    if (dbTotal >= 1000) {
      INTERESTS.forEach((t, i) => {
        counts[t.tag] = (res[i].results[0] as { n: number }).n;
      });
      total = dbTotal;
      recent = res[INTERESTS.length + 1].results as typeof recent;
    }
  } catch {
    // D1 hiccup — fall back to the baked-in numbers
  }
}

const fmt = (n: number) => n.toLocaleString("en-US");
const chipN = (t: (typeof INTERESTS)[number]) => fmt(counts[t.tag] ?? t.fb);
const dotsOf = (t: (typeof INTERESTS)[number]) =>
  Math.max(1, Math.round((counts[t.tag] ?? t.fb) / 25));

// hand-drawn arrow for the system diagram
const arrow = `<svg viewBox="0 0 56 18" width="44" height="15" aria-hidden="true"><path d="M2 11 q13 -7 26 -3 q13 4 22 -1 M42 3 l9 4 -8 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
const fmtDate = (iso: string) =>
  new Date(iso).toLocaleDateString("en-GB", { day: "numeric", month: "short" });

const person = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Subhash Kumar",
  jobTitle: "Enterprise AI Architect",
  description:
    "Mumbai-based enterprise AI architect working on agentic AI, site reliability engineering, and LLM platforms.",
  url: "https://devopsmantra.com/about/",
  image: "https://devopsmantra.com/avatar.jpg",
  email: "mailto:subhashkp@hotmail.com",
  sameAs: ["https://github.com/subhashkumarBabu"],
  address: { "@type": "PostalAddress", addressLocality: "Mumbai", addressCountry: "IN" },
  alumniOf: { "@type": "CollegeOrUniversity", name: "University of Mumbai" },
  knowsAbout: [
    "Agentic AI", "Large Language Models", "Site Reliability Engineering",
    "Microsoft Azure", "Terraform", "Solution Architecture",
    "AI coding agents", "Developer tooling",
  ],
};
---

<AirLayout
  title="About — Subhash Kumar"
  description="Subhash Kumar — Mumbai-based enterprise AI architect working on agentic AI, site reliability engineering, and LLM platforms."
  active="about"
  ogImage="/avatar.jpg"
>
  <script type="application/ld+json" set:html={JSON.stringify(person)} />

  <header class="head">
    <div>
      <h1 class="display">Subhash <em>Kumar</em></h1>
      <p class="annot">thirty years in, still shipping · mumbai</p>
    </div>
    <img class="pic" src="/avatar.jpg" alt="Subhash Kumar" width="280" height="280" />
  </header>

  <section class="card lede">
    <p class="big">
      I design enterprise AI platforms — the kind that have to survive production,
      not just a demo.
    </p>
    <p>
      Thirty years from Visual Basic to LLM agents. These days I work where
      <strong>site reliability engineering</strong> meets <strong>agentic AI</strong>:
      systems that reason, plan, call tools, remember — and still answer to
      governance and an error budget. Lately that has meant designing agentic SRE
      systems for enterprise estates — autonomous triage, routing and recovery that
      have to convince architects and auditors, not just a demo audience.
    </p>
  </section>

  <section class="sect diag-sect" aria-label="System diagram">
    <h2 class="display h2">System diagram</h2>
    <p class="annot">every architect draws themselves eventually · fig. 0</p>
    <div class="diag">
      <ul class="dcol din">
        <li><span class="dtxt">{fmt(total)} bookmarks</span><span class="arr" set:html={arrow} /></li>
        <li><span class="dtxt">chai, unmetered</span><span class="arr" set:html={arrow} /></li>
        <li><span class="dtxt">production incidents (unsolicited)</span><span class="arr" set:html={arrow} /></li>
        <li><span class="dtxt">model release notes, daily</span><span class="arr" set:html={arrow} /></li>
      </ul>
      <div class="dcore sketch">
        <p class="dname">Subhash <em>v30.0</em></p>
        <p class="dup">uptime: 30 years · unplanned restarts: 0</p>
        <div class="dmod sketch">cache — three decades of production incidents. never expires.</div>
        <div class="dmod sketch">legacy module — Visual Basic. deprecated 2002, still loaded.</div>
        <div class="dmod sketch">governance — runs "is this the right layer?" before any other process.</div>
      </div>
      <ul class="dcol dout">
        <li><span class="arr" set:html={arrow} /><span class="dtxt">agents that fix incidents</span></li>
        <li><span class="arr" set:html={arrow} /><span class="dtxt">this site — wiki, library, a curriculum</span></li>
        <li><span class="arr" set:html={arrow} /><span class="dtxt">opinions (unthrottled)</span></li>
      </ul>
    </div>
  </section>

  <section class="sect statband" aria-label="At a glance">
    <div class="stat"><span class="num">30</span><span class="lbl">years shipping</span></div>
    <div class="stat"><span class="num">{fmt(total)}</span><span class="lbl">links curated</span></div>
    <div class="stat"><span class="num">42</span><span class="lbl">wiki topics</span></div>
    <div class="stat"><span class="num">2</span><span class="lbl">learning tracks</span></div>
  </section>

  <section class="sect">
    <h2 class="display h2">Now building</h2>
    <div class="grid3">
      <div class="card proj">
        <h3>Agentic incident management</h3>
        <p>
          Autonomous agents that triage, route, and recover incidents — reasoning,
          tool calls, memory, and a policy engine, event-driven and observable end to end.
        </p>
      </div>
      <div class="card proj">
        <h3>The coding-agent craft</h3>
        <p>
          Getting real work out of AI coding agents — and knowing which one to reach for.
          Claude Code as the daily driver: harness design, hooks, skills, subagents, and
          docs written for agents as much as humans. Benchmarked honestly against GitHub
          Copilot and Codex. And always the bill: token economics, cache behaviour, the
          right model for the job.
        </p>
      </div>
      <div class="card proj">
        <h3>This site — an AI mentor in training</h3>
        <p>
          devopsmantra ingests my bookmarks, builds the <a href="/wiki/">wiki</a> and the
          searchable <a href="/library/">library</a> — and now teaches me back: a
          knowledge-graph curriculum, placement diagnostics, AI-graded recall and spaced
          repetition, two tracks live. {fmt(total)} links in, the student became the
          syllabus.
        </p>
      </div>
    </div>
  </section>

  <section class="sect">
    <h2 class="display h2">The arc</h2>
    <div class="arc">
      {ARC.map((row) => (
        <div class="row">
          <span class="when">{row.when}</span>
          <p class="what">{row.what}</p>
        </div>
      ))}
      <div class="row">
        <span class="when edu">BSc</span>
        <p class="what">
          Physics, University of Mumbai. Microsoft-certified across three decades —
          first in 2000, most recently on Azure. The tools change; the habit doesn't.
        </p>
      </div>
    </div>
  </section>

  <section class="sect">
    <h2 class="display h2">The obsession, measured</h2>
    <p class="annot">live from the vault · one dot = 25 saved links</p>
    <div class="ofield">
      {INTERESTS.map((t, i) => (
        <a class="orow" href={`/wiki/${t.slug}/`}>
          <span class="olabel">{t.label}</span>
          <span class="odots">{Array.from({ length: dotsOf(t) }).map(() => <i></i>)}</span>
          <span class="ocount">
            {i === 0 && (
              <svg class="oring" viewBox="0 0 96 40" aria-hidden="true">
                <path d="M10 20 Q14 7 48 6 T90 18 Q92 32 50 34 T8 26" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
              </svg>
            )}
            {chipN(t)}
          </span>
          {t.tag === "llms" && <span class="onote">this is fine</span>}
          {t.tag === "devops" && <span class="onote">the decline we don't discuss</span>}
        </a>
      ))}
    </div>
    {recent.length > 0 && (
      <div class="fresh">
        <p class="freshlbl">Fresh in the vault</p>
        {recent.map((r) => (
          <a class="fr" href={r.url} target="_blank" rel="noopener noreferrer">
            <span class="d">{fmtDate(r.created_at)}</span>
            <span class="t">{r.title}</span>
          </a>
        ))}
      </div>
    )}
  </section>

  <section class="sect connect">
    <h2 class="display h2">Say hello</h2>
    <p class="invite">
      If you're building agentic systems that have to survive a real enterprise
      estate — or want to compare notes on getting serious work out of coding
      agents — I'd like to hear from you.
    </p>
    <div class="ctas">
      <a class="btn accent" href="mailto:subhashkp@hotmail.com">subhashkp@hotmail.com</a>
      <a class="btn" href="https://github.com/subhashkumarBabu" target="_blank" rel="noopener noreferrer">GitHub — subhashkumarBabu</a>
      <a class="btn" href="/Subhash-Kumar-Resume.pdf" download>Résumé (PDF)</a>
    </div>
    <p class="alt">
      Not ready for hello? Start with the <a href="/wiki/ai-agents/">AI-agents wiki</a>
      or wander the <a href="/library/">library</a>.
    </p>
  </section>

  <style>
    .head {
      margin-bottom: 34px; display: flex; align-items: flex-end;
      justify-content: space-between; gap: 24px; flex-wrap: wrap;
    }
    .head h1 { font-size: clamp(44px, 8vw, 84px); }
    .head .annot { margin-top: 8px; }
    .pic { width: clamp(96px, 14vw, 140px); height: auto; border-radius: var(--r-card); }

    .lede { max-width: 720px; }
    .lede .big { font-size: clamp(17px, 2.4vw, 21px); line-height: 1.45; font-weight: 500; margin-bottom: 14px; }
    .lede p:not(.big) { color: var(--ink-2); }

    .sect { margin-top: var(--gap-section); max-width: 880px; }
    .h2 { font-size: clamp(22px, 3.5vw, 30px); margin-bottom: 16px; }

    .statband { display: flex; gap: clamp(24px, 6vw, 64px); flex-wrap: wrap; }
    .stat { display: flex; flex-direction: column; }
    .stat .num { font-family: var(--display); font-size: clamp(36px, 6vw, 60px); color: var(--whiteout); line-height: 1.05; letter-spacing: .5px; }
    .stat .lbl { color: var(--faint); font-size: 11px; text-transform: uppercase; letter-spacing: .8px; margin-top: 4px; }

    .grid3 { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 12px; }
    .proj h3 { font-family: var(--display); font-weight: 400; text-transform: uppercase; letter-spacing: .5px; font-size: 15px; margin-bottom: 8px; }
    .proj p { color: var(--ink-2); font-size: 13.5px; }
    .proj a { text-decoration: underline; text-underline-offset: 3px; }

    .arc { display: flex; flex-direction: column; max-width: 720px; }
    .arc .row {
      display: grid; grid-template-columns: 64px 1fr; gap: 16px;
      padding: 14px 0; border-top: 1px solid var(--hairline);
    }
    .arc .row:last-child { border-bottom: 1px solid var(--hairline); }
    .when { font-family: var(--display); font-size: 17px; color: var(--signal); letter-spacing: .5px; }
    .when.edu { color: var(--twilight); }
    .what { color: var(--mist); font-size: 14.5px; }

    /* ── system diagram: marker-on-whiteboard ── */
    .sketch {
      border: 2px solid var(--whiteout);
      border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px;
    }
    .diag {
      display: grid; grid-template-columns: 1fr auto 1fr; gap: 20px;
      align-items: center; max-width: 860px; margin-top: 18px;
      font-family: var(--cursive);
    }
    .dcol { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 20px; }
    .dcol li { display: flex; align-items: center; gap: 10px; }
    .din li { justify-content: flex-end; text-align: right; }
    .dtxt { font-size: 19px; color: var(--mist); line-height: 1.15; }
    .arr { color: var(--faint); flex: none; display: inline-flex; }
    .dcore { padding: 20px 22px; max-width: 330px; transform: rotate(-.4deg); }
    .dname { font-size: 30px; font-weight: 600; color: var(--whiteout); line-height: 1; }
    .dname em { font-style: normal; color: var(--signal); }
    .dup { font-size: 16px; color: var(--faint); margin: 4px 0 14px; }
    .dmod {
      padding: 9px 14px; font-size: 17px; line-height: 1.25; color: var(--mist);
      border-width: 1.5px;
      border-radius: 15px 225px 15px 255px / 255px 15px 225px 15px;
    }
    .dmod + .dmod { margin-top: 10px; }
    .dmod:nth-of-type(2) { transform: rotate(.5deg); border-radius: 225px 15px 255px 15px / 15px 255px 15px 225px; }
    .dmod:nth-of-type(3) { transform: rotate(-.3deg); }
    @media (max-width: 760px) {
      .diag { grid-template-columns: 1fr; justify-items: start; }
      .din li { justify-content: flex-start; text-align: left; }
      .dcol { gap: 10px; }
    }

    /* ── the obsession, measured: unit-dot field ── */
    .ofield { margin-top: 16px; display: flex; flex-direction: column; max-width: 860px; }
    .orow {
      display: grid; grid-template-columns: 150px 1fr auto max-content;
      gap: 14px; align-items: center; padding: 9px 0;
      border-top: 1px solid var(--hairline); color: var(--whiteout);
    }
    .orow:last-child { border-bottom: 1px solid var(--hairline); }
    .olabel { font-size: 13.5px; font-weight: 500; color: var(--mist); }
    .odots { display: flex; flex-wrap: wrap; gap: 3px; }
    .odots i { width: 7px; height: 7px; border-radius: 50%; background: var(--twilight); }
    .orow:hover .odots i { background: var(--signal); }
    .orow:hover .olabel { color: var(--whiteout); }
    .ocount {
      position: relative; font-size: 13px; font-weight: 600;
      font-variant-numeric: tabular-nums; padding: 2px 6px;
    }
    .oring {
      position: absolute; top: -8px; left: -10px;
      width: calc(100% + 20px); height: calc(100% + 16px);
      color: var(--signal); overflow: visible;
    }
    .onote { font-family: var(--cursive); font-size: 17px; color: var(--mist); white-space: nowrap; }
    @media (max-width: 640px) {
      .orow { grid-template-columns: 92px 1fr auto; }
      .onote { display: none; }
    }

    .fresh { margin-top: 22px; display: flex; flex-direction: column; max-width: 720px; }
    .freshlbl { color: var(--faint); font-size: 11px; text-transform: uppercase; letter-spacing: .8px; margin-bottom: 4px; }
    .fr {
      display: grid; grid-template-columns: 52px 1fr; gap: 12px; align-items: baseline;
      padding: 9px 0; border-top: 1px solid var(--hairline);
      color: var(--whiteout); font-size: 14px;
    }
    .fr:hover .t { color: var(--signal); }
    .fr .d { color: var(--faint); font-size: 12px; }
    .fr .t { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

    .connect .invite { color: var(--mist); font-size: 14.5px; max-width: 560px; margin-bottom: 14px; }
    .connect .ctas { display: flex; gap: 10px; flex-wrap: wrap; }
    .connect .btn { display: inline-flex; align-items: center; }
    .connect .alt { margin-top: 14px; color: var(--mist); font-size: 13.5px; }
  </style>
</AirLayout>

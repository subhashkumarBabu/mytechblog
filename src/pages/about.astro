---
import AirLayout from "../layouts/AirLayout.astro";

export const prerender = true;

const ARC = [
  {
    when: "1995",
    what: "Programmer analyst. A decade of building business software for whoever needed it — printers, financial firms, perfume makers, coaching classes, car-rental agencies. Visual Basic, FoxPro, SQL, and a lot of listening to users.",
  },
  {
    when: "2007",
    what: "Enterprise consulting: document management and .NET systems for European government and industry clients. Requirement analysis, estimation, and shipping across a portfolio of thirty-odd applications.",
  },
  {
    when: "2014",
    what: "Solutions architect for a very large UK retail estate — architectural governance, technology roadmaps, cloud and app migration measured in millions, and bringing DevOps to a legacy estate.",
  },
  {
    when: "2023",
    what: "The pivot. Site reliability engineering, large language models, and agentic AI — keeping big systems healthy, and wiring AI agents into how systems are run and how I learn.",
  },
];

const INTERESTS = [
  { label: "SRE & observability", slug: "sre-and-observability" },
  { label: "LLMs", slug: "llms" },
  { label: "AI agents", slug: "ai-agents" },
  { label: "RAG", slug: "rag" },
  { label: "Azure", slug: "azure" },
  { label: "Kubernetes", slug: "kubernetes" },
  { label: "DevOps", slug: "devops" },
  { label: "Platform engineering", slug: "platform-engineering" },
  { label: "Prompt engineering", slug: "prompt-engineering" },
  { label: "MLOps", slug: "mlops" },
];
---

<AirLayout
  title="About — Subhash Kumar"
  description="Subhash Kumar — Mumbai-based solutions architect working on site reliability engineering, LLMs, and agentic AI."
  active="about"
>
  <header class="head">
    <h1 class="display">Subhash <em>Kumar</em></h1>
    <p class="annot">thirty years in, still shipping · mumbai</p>
  </header>

  <section class="card lede">
    <p class="big">
      I'm a solutions architect whose career started with Visual Basic and currently
      runs on Kubernetes and LLM agents. For the past three years my work has centred
      on <strong>site reliability engineering</strong>, <strong>large language
      models</strong>, and <strong>agentic AI</strong>.
    </p>
    <p>
      I'm a perennial learner — physics degree, self-taught programmer, and a
      knowledge base of nearly twenty thousand curated links to prove the habit
      never stopped. This site is where that learning lives in public.
    </p>
  </section>

  <section class="sect">
    <h2 class="display h2">The arc</h2>
    <div class="arc">
      {ARC.map((row) => (
        <div class="row">
          <span class="when">{row.when}</span>
          <p class="what">{row.what}</p>
        </div>
      ))}
      <div class="row">
        <span class="when edu">BSc</span>
        <p class="what">Physics, University of Mumbai.</p>
      </div>
    </div>
  </section>

  <section class="sect">
    <h2 class="display h2">What I'm into</h2>
    <p class="annot">each chip opens the wiki page built from my saves</p>
    <div class="rail wrap chips">
      {INTERESTS.map((t) => (
        <a class="chip" href={`/wiki/${t.slug}/`}>{t.label}</a>
      ))}
    </div>
  </section>

  <section class="card sect">
    <h2 class="display h2 inkhead">This site</h2>
    <p>
      devopsmantra is my knowledge engine: 19,700+ links saved since 2012, classified
      by an LLM pipeline into a living <a href="/wiki/">wiki</a>, searchable in the
      <a href="/library/">library</a>, and resurfaced daily by a spaced-repetition
      queue. It's the proof of work for everything above.
    </p>
  </section>

  <section class="sect connect">
    <h2 class="display h2">Say hello</h2>
    <div class="ctas">
      <a class="btn accent" href="mailto:subhashkp@hotmail.com">subhashkp@hotmail.com</a>
      <a class="btn" href="https://github.com/subhashkumarBabu" target="_blank" rel="noopener noreferrer">GitHub — subhashkumarBabu</a>
    </div>
  </section>

  <style>
    .head { margin-bottom: 34px; }
    .head h1 { font-size: clamp(44px, 8vw, 84px); }
    .head .annot { margin-top: 8px; }

    .lede { max-width: 720px; }
    .lede .big { font-size: clamp(17px, 2.4vw, 21px); line-height: 1.45; font-weight: 500; margin-bottom: 14px; }
    .lede p:not(.big) { color: var(--ink-2); }

    .sect { margin-top: var(--gap-section); max-width: 720px; }
    .h2 { font-size: clamp(22px, 3.5vw, 30px); margin-bottom: 16px; }
    .inkhead { color: var(--ink); }
    .card.sect p { color: var(--ink-2); }
    .card.sect a { text-decoration: underline; text-underline-offset: 3px; }

    .arc { display: flex; flex-direction: column; }
    .arc .row {
      display: grid; grid-template-columns: 64px 1fr; gap: 16px;
      padding: 14px 0; border-top: 1px solid var(--hairline);
    }
    .arc .row:last-child { border-bottom: 1px solid var(--hairline); }
    .when { font-family: var(--display); font-size: 17px; color: var(--signal); letter-spacing: .5px; }
    .when.edu { color: var(--twilight); }
    .what { color: var(--mist); font-size: 14.5px; }

    .chips { margin-top: 14px; }
    .rail.wrap { flex-wrap: wrap; }

    .connect .ctas { display: flex; gap: 10px; flex-wrap: wrap; }
    .connect .btn { display: inline-flex; align-items: center; }
  </style>
</AirLayout>

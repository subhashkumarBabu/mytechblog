---
export const prerender = true;
import AirLayout from "@layouts/AirLayout.astro";
import { getSortedPostsList } from "@utils/content-utils";
import { getPostUrlBySlug } from "@utils/url-utils";

const posts = await getSortedPostsList();

function yearOf(d: Date | string) {
  try { return new Date(d).getFullYear(); } catch { return null; }
}

const byYear = posts.reduce<Record<number, typeof posts>>((acc, p) => {
  const y = yearOf(p.data.published) ?? 0;
  if (!acc[y]) acc[y] = [];
  acc[y].push(p);
  return acc;
}, {});

const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);
---

<AirLayout title="Blog — devopsmantra" description="Writing on SRE, AI and Cloud" active="blog">
  <header class="head">
    <h1 class="display">Blog</h1>
    <p class="annot">{posts.length} post{posts.length !== 1 ? "s" : ""} on SRE, AI and cloud</p>
  </header>

  {posts.length === 0 && <p class="annot">No posts yet.</p>}

  {years.map((year) => (
    <section class="yeargroup">
      <h2 class="sect">{year}</h2>
      <div class="list">
        {byYear[year].map((post) => {
          const date = new Date(post.data.published).toLocaleDateString("en-GB", { day: "numeric", month: "short" });
          return (
            <a class="post" href={getPostUrlBySlug(post.slug)}>
              <h3>{post.data.title}</h3>
              <span class="meta">
                {post.data.tags?.slice(0, 3).map((tag: string) => <span class="tag">{tag}</span>)}
                <span class="date">{date}</span>
              </span>
            </a>
          );
        })}
      </div>
    </section>
  ))}

  <style>
    .head { margin-bottom: var(--gap-section); }
    .head h1 { font-size: clamp(40px, 7vw, 72px); }
    .head .annot { margin-top: 8px; }

    .yeargroup { margin-bottom: var(--gap-section); }
    .sect {
      font-family: var(--display); font-weight: 400; font-size: 18px;
      letter-spacing: .5px; text-transform: uppercase; color: var(--twilight);
      margin: 0 0 16px;
    }
    .list { display: flex; flex-direction: column; gap: 14px; }
    .post {
      display: flex; align-items: baseline; justify-content: space-between; gap: 18px;
      background: var(--haze); color: var(--ink);
      border-radius: var(--r-card); padding: var(--pad-card);
      text-decoration: none;
    }
    .post:hover h3 { text-decoration: underline; text-decoration-color: var(--signal); text-underline-offset: 3px; }
    .post h3 { font-size: 17px; font-weight: 600; line-height: 1.35; }
    .post .meta {
      display: flex; align-items: baseline; gap: 12px; flex-shrink: 0;
      color: var(--ink-2); font-size: 12.5px;
    }
    .post .tag { display: none; }
    .post .date { font-variant-numeric: tabular-nums; white-space: nowrap; }
    @media (min-width: 720px) {
      .post .tag { display: inline; }
    }
  </style>
</AirLayout>

---
// "Air" app shell — midnight sky through glass.
// Rules: no gradients, no shadows/elevation, one saturated accent per page.
import "../styles/app-tokens.css";

interface Props {
  title: string;
  description?: string;
  active?: "home" | "wiki" | "library" | "today" | "stats" | "blog" | "about" | "save";
}
const { title, description = "", active = "home" } = Astro.props;

const NAV: { key: string; label: string; href: string }[] = [
  { key: "home", label: "Home", href: "/" },
  { key: "wiki", label: "Wiki", href: "/wiki/" },
  { key: "library", label: "Library", href: "/library/" },
  { key: "today", label: "Today", href: "/today/" },
  { key: "stats", label: "Stats", href: "/stats/" },
  { key: "blog", label: "Blog", href: "/archive/" },
  { key: "about", label: "About", href: "/about/" },
  { key: "save", label: "+ Save", href: "/save/" },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="color-scheme" content="dark light" />
  <meta name="theme-color" content="#0c1a38" />
  <script is:inline>
    // theme boot — before styles paint, so no flash
    const t = localStorage.getItem("theme");
    if (t === "light" || t === "dark") document.documentElement.dataset.theme = t;
  </script>
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <link rel="manifest" href="/manifest.webmanifest" />
  <link rel="icon" href="/favicon/favicon-dark-32.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=Caveat:wght@500;600&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <nav class="air-nav">
    <a class="wordmark" href="/">devopsmantra</a>
    <div class="links">
      {NAV.map((n) => (
        <a href={n.href} class:list={[{ on: n.key === active }]}>{n.label}</a>
      ))}
      <button id="themeBtn" class="themebtn" aria-label="Toggle light/dark theme" title="Toggle theme">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="12" cy="12" r="5" />
          <path d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4m11.4-11.4 1.4-1.4" />
        </svg>
      </button>
    </div>
  </nav>

  <main class="air-main">
    <slot />
  </main>

  <footer class="air-foot">
    <span class="cursive">curated by subhash · devops → ai</span>
    <a href="/about/">about</a>
  </footer>

  <style is:global>
    * { margin: 0; box-sizing: border-box; }
    html { scrollbar-color: var(--hairline) var(--void); }
    body {
      background: var(--void);
      color: var(--whiteout);
      font-family: var(--sans);
      font-size: 15px;
      line-height: 1.5;
      min-height: 100svh;
      display: flex;
      flex-direction: column;
      -webkit-font-smoothing: antialiased;
    }
    a { color: var(--signal); text-decoration: none; }
    button { font-family: var(--sans); }
    ::selection { background: var(--signal); color: #fff; }
    :focus-visible { outline: 2px solid var(--signal); outline-offset: 2px; }

    /* ── shell ── */
    .air-nav {
      max-width: var(--page-max); width: 100%; margin: 0 auto;
      display: flex; align-items: baseline; justify-content: space-between; gap: 16px;
      padding: 22px 20px 0; flex-wrap: wrap;
    }
    .wordmark {
      font-family: var(--display); font-size: 22px; letter-spacing: .5px;
      text-transform: uppercase; color: var(--whiteout);
    }
    .air-nav .links { display: flex; gap: 4px; overflow-x: auto; scrollbar-width: none; }
    .air-nav .links a {
      color: var(--mist); font-size: 13.5px; font-weight: 500;
      padding: 8px 10px; border-radius: var(--r-btn); white-space: nowrap;
    }
    .air-nav .links a.on { color: var(--whiteout); border-bottom: 2px solid var(--signal); border-radius: 0; }
    .air-nav .links a:hover { color: var(--whiteout); }
    .themebtn {
      appearance: none; cursor: pointer; border: 1px solid var(--hairline);
      border-radius: var(--r-btn); background: transparent; color: var(--mist);
      padding: 7px 9px; margin-left: 6px; display: inline-flex; align-items: center;
    }
    .themebtn:hover { color: var(--whiteout); border-color: var(--whiteout); }

    .air-main {
      max-width: var(--page-max); width: 100%; margin: 0 auto; flex: 1;
      padding: var(--gap-section) 20px 64px;
    }

    .air-foot {
      max-width: var(--page-max); width: 100%; margin: 0 auto;
      display: flex; justify-content: space-between; align-items: center;
      padding: 20px; border-top: 1px solid var(--hairline);
      color: var(--faint); font-size: 13px;
    }
    .air-foot .cursive { font-family: var(--cursive); font-size: 19px; color: var(--mist); }
    .air-foot a { color: var(--faint); }

    /* ── shared Air primitives ── */
    .display {
      font-family: var(--display); text-transform: uppercase; font-weight: 400;
      color: var(--twilight); line-height: 1.04; letter-spacing: .5px;
    }
    .display em { font-style: normal; color: var(--whiteout); }
    .annot { font-family: var(--cursive); font-size: 21px; color: var(--mist); }

    .card {
      background: var(--haze); color: var(--ink);
      border-radius: var(--r-card); padding: var(--pad-card);
    }
    .card a { color: var(--ink); }

    .btn {
      appearance: none; cursor: pointer; min-height: 44px;
      border: 1px solid var(--hairline); border-radius: var(--r-btn);
      background: transparent; color: var(--whiteout);
      font-size: 14px; font-weight: 600; padding: 10px 18px;
    }
    .btn:hover { border-color: var(--whiteout); }
    .btn.solid { background: var(--haze); border-color: var(--haze); color: var(--ink); }
    .btn.accent { background: var(--signal); border-color: var(--signal); color: #fff; }

    .input {
      width: 100%; border: 1px solid transparent; border-radius: var(--r-input);
      background: var(--haze); color: var(--ink);
      font: 500 15px var(--sans); padding: 13px 16px;
    }
    .input::placeholder { color: var(--ink-2); }
    .input:focus { outline: 2px solid var(--signal); outline-offset: 0; }

    .chip {
      flex: none; cursor: pointer; font-size: 13px; font-weight: 500;
      padding: 8px 14px; border-radius: var(--r-btn);
      border: 1px solid var(--hairline); background: transparent; color: var(--mist);
    }
    .chip:hover { color: var(--whiteout); border-color: var(--whiteout); }
    .chip.on { background: var(--signal); border-color: var(--signal); color: #fff; }

    .rail { display: flex; gap: 8px; overflow-x: auto; padding-bottom: 6px; scrollbar-width: none; }

    @media (prefers-reduced-motion: reduce) {
      * { animation: none !important; transition: none !important; }
    }
  </style>

  <script>
    if ("serviceWorker" in navigator) navigator.serviceWorker.register("/sw.js");

    const THEME_COLOR = { dark: "#0c1a38", light: "#eef2fa" };
    const metaTheme = document.querySelector<HTMLMetaElement>('meta[name="theme-color"]');
    function currentTheme(): "dark" | "light" {
      const set = document.documentElement.dataset.theme;
      if (set === "light" || set === "dark") return set;
      return matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";
    }
    if (metaTheme) metaTheme.content = THEME_COLOR[currentTheme()];
    document.getElementById("themeBtn")?.addEventListener("click", () => {
      const next = currentTheme() === "dark" ? "light" : "dark";
      document.documentElement.dataset.theme = next;
      localStorage.setItem("theme", next);
      if (metaTheme) metaTheme.content = THEME_COLOR[next];
    });
  </script>
</body>
</html>
